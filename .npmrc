# Note: pnpm v11+ no longer supports overrides in .npmrc or package.json.
# Security overrides have been moved to the root 'pnpm-workspace.yaml' file.

# # Patches XSS vulnerability in postcss CSS stringify (GHSA-qx2v-qp2m-jg93)
# overrides[postcss]=>=8.5.10
# 
# # Patches uninitialized memory disclosure in ws WebSocket (GHSA-58qx-3vcg-4xpx)
# overrides[ws]=>=8.20.0
# 
# # Patches DoS via large numeric range in brace-expansion (GHSA-jxxr-4gwj-5jf2)
# overrides[brace-expansion]=>=5.0.6

